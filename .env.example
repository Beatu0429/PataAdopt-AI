# Server configuration
PORT=4000

# Optional: enable LLM-backed AI matching explanations.
# If unset, PataAdopt-AI falls back to a built-in local matching engine (no key required).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Client configuration (Vite). Base URL of the API the frontend talks to.
VITE_API_URL=http://localhost:4000
